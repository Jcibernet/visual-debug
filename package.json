{
  "name": "@jcibernet/visual-debug",
  "version": "0.3.1",
  "description": "The agent's UI/UX inspector: ephemeral headless runs with layout SVG, geometry/accessibility heuristics, declarative multi-step flows, and run-vs-run diffs. Built for AI coding agents (Claude Code, Droid, Cursor) with zero MCP context cost.",
  "type": "module",
  "bin": {
    "visual-debug": "./visual-debug.js"
  },
  "main": "./visual-debug.js",
  "files": [
    "visual-debug.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "smoke": "node visual-debug.js https://example.com --persist-as smoke --viewport 800x600"
  },
  "dependencies": {
    "playwright": "^1.49.0"
  },
  "keywords": [
    "playwright",
    "headless",
    "chromium",
    "layout-svg",
    "ux-audit",
    "accessibility",
    "wcag",
    "performance",
    "ai-agent",
    "cli",
    "visual-regression",
    "ephemeral"
  ],
  "author": "Juan Cibernet (https://github.com/Jcibernet)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jcibernet/visual-debug.git"
  },
  "bugs": {
    "url": "https://github.com/Jcibernet/visual-debug/issues"
  },
  "homepage": "https://github.com/Jcibernet/visual-debug#readme",
  "engines": {
    "node": ">=18"
  }
}
